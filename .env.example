# Copy to .env.local and fill in. .env.local is gitignored.

# Anthropic API key created specifically for this project.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Model: Sonnet for dev/test (cost control); swap to an Opus id for the real demo.
ANTHROPIC_MODEL=claude-sonnet-4-6

# PostgreSQL connection string.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/mpkb_kitchen

# Optional: real Telegram alert in Act 1. Leave blank to disable (UI still shows the alert).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Better Auth ───────────────────────────────────────────────
# Required. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-32-byte-random-secret
# Base URL of the app (used to build magic-link URLs).
BETTER_AUTH_URL=http://localhost:3786

# Optional email provider for magic links. If RESEND_API_KEY is blank, the
# sign-in link is printed to the server console (dev) instead of emailed.
RESEND_API_KEY=
EMAIL_FROM=MPKB <onboarding@resend.dev>
