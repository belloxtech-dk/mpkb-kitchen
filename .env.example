# Copy to .env.local and fill in. .env.local is gitignored.

# Anthropic API key created specifically for this project.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Model: Sonnet for dev/test (cost control); swap to an Opus id for the real demo.
ANTHROPIC_MODEL=claude-sonnet-4-6

# SQLite file (relative to project root).
DB_FILE_NAME=./mpkb.db

# Optional: real Telegram alert in Act 1. Leave blank to disable (UI still shows the alert).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
