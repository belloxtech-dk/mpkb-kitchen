# ─── Dependencies ───────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/versions

# ─── Next.js / build output ─────────────────────────────────────
/.next/
/out/
/build
/dist
next-env.d.ts

# ─── Caches ─────────────────────────────────────────────────────
.turbo/
.cache/
*.tsbuildinfo
/coverage
.eslintcache

# ─── Environment / secrets ──────────────────────────────────────
.env
.env.local
.env*.local
.env.development.local
.env.production.local
# .env.example IS tracked (it's the template)

# ─── Logs ───────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS / editor cruft ──────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*~
.vercel
